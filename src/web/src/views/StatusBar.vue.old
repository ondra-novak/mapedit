    position: absolute;
    right: 7em;
    bottom: 2.5em;
    border: 1px solid;
    background-color: white;
    padding: 1rem;
}

.popup {
    position: fixed;
    left:0;top:0;right: 0;bottom: 0;
    background-color: #0008;
}

.popup > div {
    position: absolute;
    left:0;
    right:0;
    top: 20%;
    background-color: #ddd;
    padding: 1rem ;
    margin: auto;
    box-shadow: 3px 3px 5px black;

}

.select-project.popup > div {
    width: 60%;
    min-width: 30rem;
}unset_current_sector();
.select-project.popup .title {
    margin-bottom: 0.5rem;    
}

.popup .srl {
    height: 30vh;
    overflow: auto;
    border: 1px inset #FFF;
}
.select-project.popup .row {
    display:flex;
}
.select-project.popup .row.hdr {
    background-color: #bbb;
    position: sticky;
    top: 0;
}

.popup .row.dta {
    cursor: pointer;
}
.popup .row.dta:hover {
    background-color: white;
}

.popup .row > * {
    padding: 0.2rem;
    
}
.select-project.popup .row > *:first-child {
    flex-grow: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.select-project.popup .row > *:nth-child(2) {
    width: 5rem;
    text-align: right;
    border-left: 1px solid;
    border-right: 1px solid;

}
.select-project.popup .row > *:last-child {
    width: 11rem;
    overflow: hidden;
    text-align: right;
    white-space: nowrap;

}
.select-project.popup .nw {
    display:flex;
    gap: 0.5rem;
    align-items: center;
}
.select-project.popup .nw input {
    flex-grow: 1;
}
.left {
    display:flex;
    gap: 0.5rem;
    align-items: stretch;
    height: 2rem;
    
}

.left > .indicator {
    border-right: none;
}
.left > .indicator::before {
    content: "";
    display: inline-block;
